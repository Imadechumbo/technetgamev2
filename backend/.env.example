PORT=8080
NODE_ENV=production
HOST=0.0.0.0

SITE_NAME=TechNetGame
SITE_URL=https://technetgame.com.br
API_URL=https://api.technetgame.com.br
ALLOWED_ORIGINS=https://technetgame.com.br,https://www.technetgame.com.br,https://technetgame-site.pages.dev
CORS_ORIGIN=https://technetgame.com.br,https://www.technetgame.com.br,https://technetgame-site.pages.dev

OPENCLAW_ENABLED=true
FORCE_PRO_FOR_ALL_TEST_USERS=true
AI_REQUEST_TIMEOUT_MS=45000
AI_DEFAULT_MODEL=llama-3.3-70b-versatile
AI_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Provider principal (Groq em modo OpenAI-compatible)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Compatibilidade antiga
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Fallbacks
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Vision / multimodal
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o-mini
MAX_VISION_IMAGE_BYTES=8388608

# Refresh / segurança
REFRESH_TOKEN=troque-este-token
ALLOW_LOCAL_REFRESH_WITHOUT_TOKEN=false

# Memória persistente
TECHNET_MEMORY_MAX_ITEMS=18
TECHNET_MEMORY_MAX_SESSION_MESSAGES=32


# Hermes V7.2
HERMES_ENABLED=true
HERMES_MODE=strategic
HERMES_ROLE=memory-admin
HERMES_PRIMARY_PROVIDER=openrouter
HERMES_PRIMARY_MODEL=qwen/qwen3.6-plus:free
HERMES_SECONDARY_PROVIDER=groq
HERMES_SECONDARY_MODEL=llama-3.3-70b-versatile
HERMES_TERTIARY_PROVIDER=gemini
HERMES_TERTIARY_MODEL=gemini-2.5-flash
HERMES_FALLBACK_ENABLED=true
HERMES_FALLBACK_ORDER=openrouter,groq,gemini
HERMES_FALLBACK_TIMEOUT_MS=6000
HERMES_RETRY_ATTEMPTS=2
HERMES_AGENT_SCORING_ENABLED=true
HERMES_AGENT_PENALTY_ENABLED=true
HERMES_AGENT_PENALTY_MULTIPLIER=0.7
HERMES_AGENT_RECOVERY_RATE=0.03
HERMES_AGENT_SCORE_DECAY=0.05
HERMES_AGENT_MIN_SCORE=0.2
HERMES_AGENT_MAX_SCORE=1.0
HERMES_DECISION_ENGINE=true
HERMES_DECISION_CONFIDENCE_THRESHOLD=0.65
HERMES_REPORTS_ENABLED=true
HERMES_REPORT_WEEKLY=true
HERMES_REPORT_MONTHLY=true
HERMES_REPORT_QUARTERLY=true
HERMES_NEWS_LIMIT=60
HERMES_CRON=15 */2 * * *
